# ─── LLM Provider ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=incident_user
POSTGRES_PASSWORD=incident_pass
POSTGRES_DB=incidents

# ─── Services ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
WEAVIATE_URL=http://localhost:8080
DATABASE_URL=postgresql://incident_user:incident_pass@localhost:5432/incidents

# ─── Anomaly Detection ─────────────────────────────────────────────────────────
DETECTION_INTERVAL_SECONDS=15
LATENCY_P95_THRESHOLD_MS=5000
ERROR_RATE_CRITICAL_THRESHOLD=0.10
ERROR_RATE_WARNING_THRESHOLD=0.05
CPU_WARNING_THRESHOLD=0.80
MEMORY_WARNING_THRESHOLD=0.85

# ─── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
